# MongoDB
# When running via Docker Compose, use the service name "mongo" as the host.
# When running locally, use "localhost".
MONGO_URI=mongodb://mongo:27017
DATABASE_NAME=post_scheduler

# X / Twitter
# Get these from: https://developer.twitter.com → your project → app → Keys and Tokens
# OAuth 1.0a with Read & Write permissions required.
TWITTER_API_KEY_MAIN=
TWITTER_API_SECRET_MAIN=
TWITTER_API_BEARER_TOKEN_MAIN=
TWITTER_API_ACCESS_TOKEN_MAIN=
TWITTER_API_ACCESS_TOKEN_SECRET_MAIN=

# Reddit
# Get these from: https://www.reddit.com/prefs/apps → Create App → script
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=test

# Telegram
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Add the bot as Admin to your channel (must have "Post Messages" permission)
# 3. Public channel: @yourchannel | Private channel: -1001234567890
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Discord
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
